# Production env-var template for Render.
# Copy values you need into the Render dashboard. NEVER commit a filled-in .env.

# Mandatory in production
FLASK_ENV=production
FLASK_SECRET_KEY=<long-random-string>     # Render can auto-generate
DATABASE_URL=postgres://user:pass@host/db # from Neon (use the "pooled" connection string)
APP_BASE_URL=https://powertheworld.onrender.com

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Task Tracker <onboarding@resend.dev>
EMAIL_TEST_TO=powertheworldwithbryan@gmail.com   # used as the seed admin email on first deploy
